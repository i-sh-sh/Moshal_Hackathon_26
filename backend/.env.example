# Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# ── Server ──────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Auth — JWT ───────────────────────────────────────────────────────────
# REQUIRED in production. Use `openssl rand -base64 48` to generate.
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string-of-at-least-32-bytes
JWT_ACCESS_TTL_SECONDS=900           # 15 min
JWT_REFRESH_TTL_SECONDS=604800       # 7 days
JWT_ISSUER=teamsprintup

# ── Auth — provider selection & policy ──────────────────────────────────
# One of: local, firebase, google
AUTH_PROVIDER=local
BCRYPT_COST=12
ALLOW_SELF_REGISTRATION=false        # production schools provision via admin API
AUTH_MAX_FAILED_LOGINS=5
AUTH_LOCKOUT_WINDOW_SECONDS=900

# ── Seed ─────────────────────────────────────────────────────────────────
# Used by `npm run seed`. Override for non-default demo password.
SEED_DEMO_PASSWORD=demo1234

# ── AI (Azure OpenAI) ────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-azure-api-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_WHISPER_DEPLOYMENT=whisper

# ── Monday.com ───────────────────────────────────────────────────────────
# Optional — backend gracefully no-ops without these. Simulator covers demos.
MONDAY_API_TOKEN=
MONDAY_WEBHOOK_SECRET=

# ── Integrations — mock vs. real ─────────────────────────────────────────
# Flip to "real" once credentials are installed. Defaults are mock.
FIREBASE_PROVIDER=mock
STORAGE_PROVIDER=mock
TECHSCHOOL_PROVIDER=mock

# ── Firebase (when FIREBASE_PROVIDER=real) ───────────────────────────────
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# FIREBASE_PROJECT_ID=teamsprintup-prod

# ── AWS S3 (when STORAGE_PROVIDER=real) ──────────────────────────────────
# AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# STORAGE_BUCKET=teamsprintup-uploads

# ── Tech School (when TECHSCHOOL_PROVIDER=real) ──────────────────────────
# TECHSCHOOL_API_URL=https://api.techschool.example
# TECHSCHOOL_API_TOKEN=...

# ── Gatekeeper overrides (optional) ──────────────────────────────────────
# GATEKEEPER_AZURE_RPM=60
# GATEKEEPER_MONDAY_RPM=60
