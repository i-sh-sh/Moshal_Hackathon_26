# Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# ── Server ────────────────────────────────────────────────────
PORT=3001

# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── AI (Azure OpenAI) ─────────────────────────────────────────
# Found in: Azure Portal → Cognitive Services → Azure OpenAI → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE_NAME.openai.azure.com/
AZURE_OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_OPENAI_API_VERSION=2024-02-01
# The deployment name you created in Azure OpenAI Studio (e.g. gpt-4o, gpt-4, gpt-35-turbo)
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# ── Monday.com (optional — simulator used for demo) ───────────
MONDAY_API_TOKEN=eyJhbGciOiJIUzI1NiJ9...
MONDAY_WEBHOOK_SECRET=choose-any-random-string

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev: http://localhost:3000
# Production: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000
