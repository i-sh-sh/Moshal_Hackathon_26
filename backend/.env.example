# Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# ── Server ──────────────────────────────────────────────────────────────
PORT=3001

# ── Database (Neon PostgreSQL) ───────────────────────────────────────────
# Found in: Neon dashboard → Connection Details → Connection string
# Format: postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/teamsprintup?sslmode=require

# ── AI (Anthropic Claude) ────────────────────────────────────────────────
# Found in: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Monday.com (optional — simulator used for demo) ──────────────────────
MONDAY_API_TOKEN=eyJhbGciOiJIUzI1NiJ9...
MONDAY_WEBHOOK_SECRET=choose-any-random-string

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev: http://localhost:3000
# Production: https://your-app.netlify.app
CORS_ORIGINS=http://localhost:3000
