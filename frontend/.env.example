# Frontend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
#
# Nuxt 3 naming convention:
#   NUXT_PUBLIC_*  → available in browser AND server
#   NUXT_*         → server-side only (never sent to browser)

# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NUXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NUXT_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Backend API ────────────────────────────────────────────────
# Local dev:   http://localhost:3001/api
# Production:  https://your-backend.railway.app/api  ← set after Railway deploy
NUXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
