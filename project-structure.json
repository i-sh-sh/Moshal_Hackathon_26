{
  "project": {
    "name": "SprintUp",
    "description": "Progress Intelligence layer over TechSchool's existing LMS. Measures the path students take through 3D-modeling missions — task progress, AI-bot use, jargon understanding, evidence uploads, and team activity — and surfaces it to teachers and mentors. Does NOT replace the LMS.",
    "positioning": "Not a new LMS. Not a free AI chat. Not a file dropbox. SprintUp adds the missing analytics + process layer on top of TechSchool's existing 3-product/year flow.",
    "version": "1.1.0",
    "repository": "https://github.com/i-sh-sh/Moshal_Hackathon_26",
    "stack": {
      "frontend": "Nuxt 3 (Vue 3) + TailwindCSS",
      "backend": "NestJS + TypeScript",
      "database": "Supabase (PostgreSQL)",
      "ai": "Anthropic Claude (claude-sonnet-4-6)",
      "mondayIntegration": "Monday.com GraphQL API + Simulator (legacy from v1)"
    },
    "deployment": {
      "frontend": "Vercel (SSR)",
      "backend": "Railway",
      "database": "Supabase (hosted)"
    },
    "teamSplit": {
      "ourTeam_nissim": [
        "Role assignment to students for 3D-print missions (TeacherModule)",
        "Pre/post-mission quizzes — knowledge measurement (planned)"
      ],
      "otherTeam": [
        "Azure setup",
        "In-app chat / Discord-style channels"
      ]
    },
    "personas": ["student", "teacher", "mentor", "admin"]
  },

