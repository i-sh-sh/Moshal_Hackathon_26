  "rag": {
    "strategy": "in-memory JSON (TypeScript constant)",
    "file": "backend/src/rag/syllabus.ts",
    "sprintMapping": {
      "bbbb0001-0000-0000-0000-000000000000": "אתגר 01 — מתנה",
      "bbbb0002-0000-0000-0000-000000000000": "אתגר 02 — משחקים",
      "bbbb0003-0000-0000-0000-000000000000": "אתגר 03 — מיתוג אישי"
    },
    "contextInjectedToPrompt": [
      "syllabus.hebrewTitle + period + sessionsCount",
      "syllabus.coreTopics",
      "syllabus.fusion360Techniques (name + description + relevance)",
      "syllabus.skillsToLearn",
      "syllabus.cblGoal",
      "syllabus.peakEvent",
      "teamProgress (approvedCount/totalCount)",
      "hintNumber + isLastFreeHint + isOverFreeLimit",
      "task title + description + role",
      "hint depth instruction based on number"
    ],
