  "architecture": {
    "overview": "Teacher triggers challenges via Monday.com (or simulator) → NestJS processes webhooks → Tasks flow through approval pipeline (Dev→QA→PM→Teacher) → Supabase stores all state → Nuxt frontend reflects live data",
    "taskStatusFlow": [
      "pending",
      "qa_review",
      "pm_review",
      "teacher_review",
      "approved"
    ],
    "taskStatusFlowDescription": "Dev submits → QA reviews (checklist) → PM approves (triggers Monday update + hardware LED) → Teacher approves via Monday webhook → team completion checked",
    "roles": ["designer", "editor", "qa", "printer"],
    "roleTaxonomyNote": "Pivoted 2026-05-07 from pm/qa/dev/hardware to designer/editor/qa/printer for 3D-print missions. Mapping: dev→designer, pm→editor, hardware→printer, qa unchanged.",
    "hintSystem": {
      "freeHintsPerUserPerTeam": 3,
      "pointsDeductedPerExtraHint": 10,
      "counterResetsOnTeamChange": true,
      "ragEnabled": true,
      "ragStrategy": "in-memory syllabus JSON keyed by sprint UUID"
    }
  },

  "database": {
    "platform": "Supabase (PostgreSQL)",
    "schemaFile": "supabase/schema.sql",
    "tables": {
      "challenges": {
        "description": "פרויקטים גדולים — Smart City, Tech School 3D וכו'",
        "keyColumns": ["id", "title", "monday_board_id", "is_active", "order_index"]
      },
      "teams": {
        "description": "צוותי תלמידים עם ניקוד ומצב ספרינט",
        "keyColumns": ["id", "name", "accumulated_score", "sprint_status", "is_completed", "current_challenge_id", "current_sprint_id"]
      },
      "users": {
        "description": "תלמידים עם תפקיד דינמי לפי challenge",
        "keyColumns": ["id", "name", "email", "current_team_id", "current_role", "total_active_time"]
      },
      "sprints": {
        "description": "שלבי-משנה בתוך challenge",
        "keyColumns": ["id", "challenge_id", "title", "order_index"]
      },
      "tasks": {
        "description": "משימות בודדות עם lifecycle מלא",
        "keyColumns": ["id", "sprint_id", "team_id", "assigned_role", "title", "status", "submission_url", "monday_item_id", "qa_checklist", "submitted_by", "reviewed_by_qa", "reviewed_by_pm"]
      },
      "hint_logs": {
        "description": "תיעוד כל בקשת hint — user, team, task, hint_text, points_deducted",
        "keyColumns": ["id", "user_id", "team_id", "task_id", "hint_number", "hint_text", "points_deducted"]
      },
      "team_hint_counters": {
        "description": "סופר hints לפי (user, team) — מתאפס אוטומטית כשמחליפים צוות",
        "keyColumns": ["user_id", "team_id", "hint_count"],
        "uniqueConstraint": ["user_id", "team_id"]
      }
    },
    "views": {
      "group_leaderboard": "דירוג צוותים לפי accumulated_score + approved_task_count",
      "individual_leaderboard": "דירוג אישי לפי משימות שאושרו — backend מחזיר top 3 בלבד",
      "teacher_analytics": "זמן פעיל vs. tasks/שעה לכל תלמיד (proxy לניתוח rushing/struggling)"
    },
    "rpcFunctions": {
      "add_team_score": "הוספה atomic לניקוד צוות",
      "deduct_team_score": "ניכוי atomic עם floor=0"
    },
    "rls": "Backend משתמש ב-service-role key (עוקף RLS). Frontend משתמש ב-anon key — כל משתמש רואה רק את הנתונים שלו ושל הצוות שלו."
  },

  "backend": {
    "framework": "NestJS",
    "port": 3001,
    "globalPrefix": "/api",
    "entryPoint": "backend/src/main.ts",
    "rootModule": "backend/src/app.module.ts",

    "modules": {
      "SupabaseModule": {
        "path": "backend/src/supabase/",
        "files": ["supabase.service.ts", "supabase.module.ts"],
        "scope": "Global",
        "description": "Supabase client עם service-role key. מוזרק אוטומטית לכל המודולים.",
        "keyMethod": "get db(): SupabaseClient"
      },
      "TasksModule": {
        "path": "backend/src/tasks/",
        "files": ["tasks.service.ts", "tasks.controller.ts", "tasks.module.ts", "dto/submit-task.dto.ts", "dto/qa-review.dto.ts", "dto/pm-review.dto.ts"],
        "description": "לוגיקת pipeline המשימות המלאה עם role validation.",
        "methods": {
          "submitTask": "pending/rejected → qa_review (Dev/Hardware בלבד)",
          "qaReview": "qa_review → pm_review (approve) או pending (reject)",
          "pmReview": "pm_review → teacher_review + Monday update + LED event (approve) או qa_review (reject)",
          "teacherApprove": "teacher_review → approved + checkAndCompleteTeam()"
        },
        "endpoints": [
          { "method": "GET",  "path": "/api/tasks/team/:teamId", "description": "כל משימות הצוות" },
          { "method": "POST", "path": "/api/tasks/submit",       "description": "הגשת עבודה (Dev/Hardware)" },
          { "method": "POST", "path": "/api/tasks/qa-review",    "description": "אישור/דחיית QA" },
          { "method": "POST", "path": "/api/tasks/pm-review",    "description": "אישור/דחיית PM" }
        ]
      },
      "HintsModule": {
        "path": "backend/src/hints/",
        "files": ["hints.service.ts", "hints.controller.ts", "hints.module.ts", "dto/request-hint.dto.ts"],
        "description": "מערכת hints: 3 חינמיים → ניכוי 10 נקודות. משתמש ב-RagService לcontext.",
        "methods": {
          "requestHint": "buildContext() → generateHint(ctx) → log → upsert counter → deduct if over limit",
          "getHintCount": "מחזיר hint_count לפי (userId, teamId)",
          "getHintHistory": "היסטוריית hints לפי (userId, teamId)"
        },
        "endpoints": [
          { "method": "POST", "path": "/api/hints",              "description": "בקשת hint" },
          { "method": "GET",  "path": "/api/hints/count",        "description": "?userId=&teamId=" },
          { "method": "GET",  "path": "/api/hints/history",      "description": "?userId=&teamId=" }
        ]
      },
      "TeamsModule": {
        "path": "backend/src/teams/",
        "files": ["teams.service.ts", "teams.controller.ts", "teams.module.ts"],
        "description": "ניקוד, בדיקת סיום צוות, leaderboards ואנליטיקס.",
        "methods": {
          "checkAndCompleteTeam": "אם כל משימות הספרינט approved → is_completed=true, sprint_status=completed",
          "getGroupLeaderboard": "כל הצוותים ממוינים לפי ניקוד",
          "getIndividualLeaderboard": "top 3 בלבד",
          "getTeacherAnalytics": "active_time vs tasks/hour לכל תלמיד"
        },
        "endpoints": [
          { "method": "GET", "path": "/api/teams/leaderboard/group",       "description": "דירוג צוותים" },
          { "method": "GET", "path": "/api/teams/leaderboard/individual",  "description": "top 3 אישי" },
          { "method": "GET", "path": "/api/teams/analytics",               "description": "analytics למורה" }
        ]
      },
      "AIModule": {
        "path": "backend/src/ai/",
        "files": ["ai.service.ts", "ai.module.ts"],
        "model": "claude-sonnet-4-6",
        "description": "Claude API wrapper. analyze() לטקסט, generateHint() עם HintContext מלא.",
        "methods": {
          "analyze": "מחזיר jargonScore, softSkillScore, detectedTerms, suggestions",
          "generateHint": "מקבל HintContext מלא מ-RagService, מחזיר hint מעורב עברית/אנגלית"
        }
      },
      "RagModule": {
        "path": "backend/src/rag/",
        "files": ["rag.service.ts", "rag.module.ts", "syllabus.ts"],
        "description": "RAG in-memory: סילבוס Tech School מובנה ב-TypeScript, context builder לhints.",
        "strategy": "Sprint UUID → SYLLABUS_BY_SPRINT lookup → SprintSyllabus object",
        "syllabusContent": {
          "sprint_gift_bbbb0001":     "אתגר 01 — מתנה: יסודות תלת-מימד, Sketch/Extrude/Fillet",
          "sprint_games_bbbb0002":    "אתגר 02 — משחקים: Assembly, Joints, Pattern, Mirror",
          "sprint_branding_bbbb0003": "אתגר 03 — מיתוג אישי: Scale, Emboss, Shell, Loft"
        },
        "contextBuilt": ["taskTitle", "taskDescription", "assignedRole", "syllabus", "fusion360Techniques", "teamProgress", "hintNumber", "isLastFreeHint", "isOverFreeLimit"]
      },
      "MondayApiModule": {
        "path": "backend/src/monday/",
        "files": ["monday-api.service.ts", "monday-api.module.ts"],
        "description": "GraphQL client ל-Monday.com API האמיתי.",
        "methods": {
          "updateItemStatus": "שינוי סטטוס עמודה על item",
          "createItem": "יצירת item חדש על board"
        }
      },
      "WebhooksModule": {
        "path": "backend/src/webhooks/",
        "files": ["monday.controller.ts", "webhooks.module.ts"],
        "description": "מקבל webhook events נכנסים מ-Monday.com.",
        "handledEvents": {
          "create_pulse": "Challenge kickoff → מפעיל challenge לכל הצוותים",
          "change_column_value": "Teacher approval → מפעיל teacherApprove()"
        },
        "endpoints": [
          { "method": "POST", "path": "/api/webhooks/monday", "description": "Monday.com webhook endpoint" }
        ]
      },
      "MockMondayModule": {
        "path": "backend/src/mock-monday/",
        "files": ["mock-monday.service.ts", "mock-monday.controller.ts", "mock-monday.module.ts"],
        "description": "סימולטור Monday.com לדמו. מפעיל את אותה לוגיקה כמו webhook אמיתי.",
        "endpoints": [
          { "method": "GET",  "path": "/api/mock-monday/challenges",        "description": "רשימת challenges" },
          { "method": "GET",  "path": "/api/mock-monday/board/:challengeId","description": "board ב-5 עמודות" },
          { "method": "POST", "path": "/api/mock-monday/kickoff/:challengeId","description": "הפעלת challenge" },
          { "method": "POST", "path": "/api/mock-monday/approve/:taskId",   "description": "אישור teacher" },
          { "method": "POST", "path": "/api/mock-monday/reject/:taskId",    "description": "דחיית teacher" }
        ]
      }
    },

    "scripts": {
      "start:dev": "nest start --watch (localhost:3001)",
      "build": "nest build",
      "start:prod": "node dist/main",
      "seed": "ts-node --project tsconfig.json src/seed.ts"
    },

    "envVars": {
      "PORT": "פורט השרת (ברירת מחדל: 3001)",
      "SUPABASE_URL": "Supabase project URL",
      "SUPABASE_SERVICE_ROLE_KEY": "Service role key — עוקף RLS",
      "ANTHROPIC_API_KEY": "Claude API key",
      "MONDAY_API_TOKEN": "Monday.com GraphQL token",
      "MONDAY_WEBHOOK_SECRET": "אימות webhook נכנס",
      "CORS_ORIGINS": "דומיינים מורשים מופרדים בפסיק"
    }
  },

  "frontend": {
    "framework": "Nuxt 3 (Vue 3)",
    "mode": "SSR",
    "port": 3000,
    "configFile": "frontend/nuxt.config.ts",

    "pages": {
      "/": "ממשק תלמידים (טרם נבנה — TaskBoard מוכן לשילוב)",
      "/teacher": "ממשק מורה — סימולטור Monday.com"
    },

    "components": {
      "TaskBoard.vue": {
        "path": "frontend/components/TaskBoard.vue",
        "description": "לוח משימות עם כפתורים שונים לפי תפקיד.",
        "props": ["tasks: Task[]", "currentRole: UserRole", "userId: string", "teamId: string"],
        "emits": ["submit-task", "qa-review", "pm-review", "request-hint"],
        "roleBasedUI": {
          "dev/hardware": "כפתור Submit Work עם טופס URL",
          "qa": "כפתור QA Review עם checklist + improvements",
          "pm": "כפתור PM Review עם תצוגת QA summary",
          "all": "כפתור Hint 💡 על כל משימה פתוחה"
        }
      },
      "EnglishTerm.vue": {
        "path": "frontend/components/EnglishTerm.vue",
        "description": "מונח אנגלי עם tooltip עברי בhover.",
        "props": ["term: string", "translation?: string"],
        "builtInGlossary": 30,
        "usage": "<EnglishTerm term=\"Sprint\" /> → tooltip: 'ספרינט (מחזור פיתוח קצר)'"
      },
      "MockMondayBoard.vue": {
        "path": "frontend/components/MockMondayBoard.vue",
        "description": "ממשק מורה בסגנון Monday.com — 5 עמודות, approve/reject, kickoff.",
        "columns": ["In Progress", "QA Review", "PM Review", "Pending Teacher Review", "Approved"],
        "features": ["challenge selector", "kickoff button", "approve/reject per item", "toast notifications", "auto-refresh after action"]
      }
    },

    "composables": {
      "useTasks": {
        "path": "frontend/composables/useTasks.ts",
        "description": "Typed API wrappers לכל task + hint operations. מרענן tasks אוטומטית אחרי כל פעולה.",
        "exports": ["tasks", "loading", "error", "fetchTasks", "submitTask", "qaReview", "pmReview", "requestHint"]
      }
    },

    "types": {
      "path": "frontend/types/types.ts",
      "description": "TypeScript interfaces משותפות — חייבים להישאר מסונכרנים עם backend DTOs.",
      "exports": ["UserRole", "User", "Team", "Challenge", "Sprint", "Task", "TaskStatus", "QaChecklist", "HintResponse", "GroupLeaderboardRow", "IndividualLeaderboardRow", "AIAnalysisResult"]
    },

    "services": {
      "mockService": {
        "path": "frontend/services/mockService.ts",
        "description": "נתוני דמה לפיתוח frontend ללא backend חי. יש להחליף בקריאות API אמיתיות."
      }
    },

    "envVars": {
      "NUXT_PUBLIC_SUPABASE_URL": "Supabase project URL (browser + server)",
      "NUXT_PUBLIC_SUPABASE_ANON_KEY": "Supabase anon key — בטוח לחשוף",
      "NUXT_SUPABASE_SERVICE_KEY": "Service key — server-side routes בלבד",
      "NUXT_PUBLIC_API_BASE_URL": "URL של ה-NestJS backend"
    }
  },

